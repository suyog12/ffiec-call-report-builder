# ─────────────────────────────────────────────────────────────
# FFIEC Call Report App — Environment Template
# Copy this file to .env and fill in your values.
# NEVER commit .env — only commit .env.example
# ─────────────────────────────────────────────────────────────

# ── FFIEC API ─────────────────────────────────────────────────
FFIEC_BASE_URL=https://ffieccdr.azure-api.us/public
FFIEC_USER_ID=your_ffiec_user_id
FFIEC_PWS_TOKEN=your_ffiec_pws_token

# ── Backend server ────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
# Local dev: BACKEND_URL=http://127.0.0.1:8000
# Production: BACKEND_URL=https://your-render-service.onrender.com
BACKEND_URL=http://127.0.0.1:8000

# ── Cloudflare R2 ─────────────────────────────────────────────
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=ffiec-data

# ── AI Agent ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── BigData ───────────────────────────────────────────────────
UBPR_NUM_QUARTERS=8

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://your-vercel-app.vercel.app
