# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# FFIEC CDR API credentials
# Register at https://cdr.ffiec.gov to obtain a user ID and token.
FFIEC_BASE_URL=https://ffieccdr.azure-api.us/public
FFIEC_USER_ID=your_ffiec_user_id
FFIEC_PWS_TOKEN=your_ffiec_pws_token

# Server settings
APP_HOST=127.0.0.1
APP_PORT=8000
